---
extends: default

rules:
  # Discourse container configs routinely exceed 80 chars (long URLs, env
  # interpolation). 120 is a reasonable ceiling for humans.
  line-length:
    max: 120
    level: warning

  # Don't require --- at start of every file. Discourse's own app.yml
  # templates don't have it either; matching upstream convention.
  document-start: disable

  # Allow two-space indentation inside lists (default is stricter).
  indentation:
    spaces: 2
    indent-sequences: consistent
    check-multi-line-strings: false

  # Trailing spaces are still an error (good default).
  # Comments must have a space after #.
  comments:
    min-spaces-from-content: 1

  # Allow truthy values like 'yes'/'no' (used by Discourse templates).
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no']
    check-keys: false
