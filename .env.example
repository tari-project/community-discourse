# =============================================================================
# Tari Community Discourse — environment template
# =============================================================================
# Copy to .env and fill in. NEVER commit the real .env.
# -----------------------------------------------------------------------------

# --- Host / domain ------------------------------------------------------------
# The FQDN users will hit. DNS A/AAAA records must point at this host BEFORE
# install.sh runs, or Let's Encrypt will fail to issue the cert.
FORUM_DOMAIN=forum.tari.com

# --- Administrator ------------------------------------------------------------
# The bootstrap admin account. Gets full staff permissions. Hand this off at
# completion (see docs/HANDOVER.md).
ADMIN_EMAIL=admin@tari.com
ADMIN_USERNAME=tari_admin

# --- SMTP (required — Discourse cannot operate without outbound email) --------
# Recommended: Mailgun, SendGrid, Amazon SES, or Postmark.
# The install script will refuse to continue if SMTP_ADDRESS is unset.
SMTP_ADDRESS=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER_NAME=postmaster@mg.tari.com
SMTP_PASSWORD=CHANGE_ME  # pragma: allowlist secret
SMTP_DOMAIN=mg.tari.com
NOTIFICATION_EMAIL=noreply@tari.com

# --- Container sizing ---------------------------------------------------------
# Tune for your VPS. Defaults target a 4 vCPU / 16 GB box.
DB_SHARED_BUFFERS=2048MB
UNICORN_WORKERS=6

# --- Backups ------------------------------------------------------------------
# Local backups are always on. Set S3_* to enable offsite.
BACKUP_RETENTION_DAYS=14
S3_BACKUP_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- GitHub SSO (optional — see docs/GITHUB_SSO_SETUP.md) ---------------------
# Leave blank to defer SSO wiring until after initial stand-up.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Let's Encrypt ------------------------------------------------------------
# Same as ADMIN_EMAIL by default. Used for cert renewal notifications.
LETSENCRYPT_ACCOUNT_EMAIL=admin@tari.com

# --- Discourse version pin ----------------------------------------------------
# Pin to a specific tag for reproducible rebuilds. Bump deliberately during
# scheduled upgrade windows (see docs/OPERATIONS.md).
DISCOURSE_VERSION=stable
